rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // tacoSpots — public read, no writes from client
    match /tacoSpots/{spotId} {
      allow read: if true;
      allow write: if false;
    }

    // hunts — public read; all writes go through server-side API routes (Admin SDK)
    match /hunts/{huntId} {
      allow read: if true;
      allow write: if false;
    }

    // participants subcollection — public read for leaderboard; server-only writes
    match /hunts/{huntId}/participants/{userId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
